# ─────────────────────────────────────────────
# native-openclaw — Environment Configuration
# Copy to .env and fill in actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_ENV=development           # development | production | test
LOG_LEVEL=info                # debug | info | warn | error
APP_DATA_DIR=.data            # relative path for storage (sessions, history)
WORKSPACE_DIR=./workspace     # human-readable workspace root
WORKSPACE_ALLOW_OUTSIDE_PATHS=false
WORKFLOW_FILE=./workspace/WORKFLOW.md
WORKSPACE_MEMORY_ENABLED=true
WORKSPACE_DAILY_MEMORY_ENABLED=true

# Scheduler / Cronjobs
SCHEDULER_ENABLED=true
SCHEDULER_TICK_MS=30000
SCHEDULER_TIMEZONE=Asia/Jakarta
SCHEDULER_MISFIRE_POLICY=skip
SCHEDULER_SESSION_MODE=dedicated
SCHEDULER_MAX_CONCURRENT_JOBS=2
SCHEDULER_RUN_HISTORY_LIMIT=100

# HTTP API
API_ENABLED=false
API_HOST=127.0.0.1
API_PORT=18789
API_AUTH_TOKEN=
# Rate limiting is enabled by default for non-loopback API hosts.
# Loopback hosts bypass it unless RATE_LIMIT_ENABLED=true.
# Set to false only for deployments that are never reachable externally.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=10
# Comma-separated IPs of trusted reverse proxies (e.g. Nginx, Traefik).
# Only when set will X-Forwarded-For be trusted for rate limiting.
# TRUSTED_PROXY_IPS=

# Web UI
WEB_UI_ENABLED=false
WEB_UI_HOST=0.0.0.0
WEB_UI_PORT=18790
WEB_UI_USERNAME=admin
WEB_UI_PASSWORD=change-me
WEB_UI_SESSION_SECRET=change-this-secret
WEB_UI_COOKIE_NAME=native_openclaw_webui
WEB_UI_SESSION_TTL_MS=86400000

# Web UI Puter.ai
WEB_UI_PUTER_ENABLED=false
WEB_UI_PUTER_PROVIDER_ID=puter
WEB_UI_PUTER_DEFAULT_MODEL=gpt-5-nano

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOW_ALL=false

# Telegram responsiveness
TELEGRAM_ACK_ENABLED=true
TELEGRAM_ACK_MESSAGE=Sedang diproses...
TELEGRAM_PROCESS_TIMEOUT_MS=90000
TELEGRAM_LOG_POLLING_ERRORS=false   # When false, suppresses all polling error logging (conflict + non-conflict). When true, logs at warn level.
TELEGRAM_RETRY_MIN_MS=3000
TELEGRAM_RETRY_MAX_MS=60000
TELEGRAM_POLL_TIMEOUT=25
TELEGRAM_QUEUE_NOTICE_ENABLED=false
TELEGRAM_SUPPRESS_CONFLICT_ERRORS=true
TELEGRAM_CONFLICT_BACKOFF_MS=60000
TELEGRAM_RECOVERY_LOG_ENABLED=false

# Network
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,openclaw,ollama,host.docker.internal,.local,.internal
DNS_SERVERS=8.8.8.8,1.1.1.1

# MCP
MCP_ENABLED=true
MCP_CONFIG_PATH=./mcp_agent.config.yaml
MCP_AUTO_START=false

# MCP Agent self-configuration
MCP_AGENT_ENABLED=true
MCP_AGENT_CONFIG_PATH=./mcp_agent.config.yaml
MCP_AGENT_ALLOW_CONFIG_WRITE=true

# Lightweight Agent Gateway
AGENT_GATEWAY_ENABLED=true
AGENT_GATEWAY_MAX_DELEGATION_DEPTH=1
AGENT_GATEWAY_DEFAULT_TIMEOUT_MS=900000
AGENT_GATEWAY_MAX_FALLBACKS=2
AGENT_GATEWAY_VALIDATE_RESULTS=true
AGENT_OPENCODE_ENABLED=true
AGENT_INTERNAL_CODING_ENABLED=true
AGENT_INTERNAL_CODING_MAX_PROMPT_CHARS=24000
AGENT_MCP_ENABLED=true

# ── Providers ────────────────────────────────
# Enable only the providers you have keys for.

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Anthropic model ID format: claude-{version}-{date}
# Check latest models at: https://docs.anthropic.com/en/docs/models-overview
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-20250514

# Google Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# ── Agent defaults ────────────────────────────
AGENT_MAX_TURNS=20
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=4096
AGENT_SYSTEM_PROMPT=You are a helpful AI assistant.

# Prompt Optimizer
PROMPT_OPTIMIZER_ENABLED=true
PROMPT_OPTIMIZER_MODEL=
PROMPT_OPTIMIZER_MODE=balanced
PROMPT_OPTIMIZER_MAX_INPUT_CHARS=12000
PROMPT_OPTIMIZER_MAX_CONTEXT_CHARS=24000
PROMPT_OPTIMIZER_MAX_TOOL_RESULT_CHARS=8000
PROMPT_OPTIMIZER_TARGET_MODEL_SMALL=true
PROMPT_OPTIMIZER_LOG_SUMMARY=true
PROMPT_OPTIMIZER_STORE_RUNS=true
PROMPT_SKILL_RELEVANCE_ENABLED=true
PROMPT_MAX_ACTIVE_SKILLS=3

# ── Storage ───────────────────────────────────
STORAGE_BACKEND=file          # file | memory (sqlite planned)

# Groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# Mistral AI
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_DEFAULT_MODEL=mistral-large-latest

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=

# Z.ai
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-4.5

# Puter.ai backend provider
# Puter is used only through the backend ProviderRouter. Direct frontend
# Puter.js final-answer mode is disabled because it bypasses tools.
PUTER_ENABLED=false
PUTER_API_KEY=
PUTER_BASE_URL=
PUTER_DEFAULT_MODEL=gpt-5.5
PUTER_DISABLE_TEMPERATURE=true
PUTER_TEMPERATURE=
PUTER_REASONING_MODELS_DISABLE_TEMPERATURE=true

# Brevo
BREVO_API_KEY=
BREVO_SENDER_EMAIL=email-pengirim@gmail.com
BREVO_SENDER_NAME=Native OpenClaw
BREVO_RECIPIENT_EMAIL=email-penerima@gmail.com
BREVO_RECIPIENT_NAME=

# Ollama (local — no key required)
OLLAMA_BASE_URL=http://localhost:11434

# ── Skills ────────────────────────────────────────────────────────────────────
SKILLS_DIR=./skills            # path to .md skill files directory

# Self-Improving Skill Loop (Hermes-style)
# Set to "true" to enable automatic skill extraction and self-evaluation.
# When running in Docker, generated skills are stored under SKILLS_DIR/auto-generated
# and quality metrics under APP_DATA_DIR/skill-quality.json.
SELF_IMPROVING=false
SELF_IMPROVING_EVAL_THRESHOLD=10
# Optional preferred model for self-improvement.
# Leave empty to use the default router and auto-fallback.
# Format: provider/model, e.g. groq/llama-3.3-70b-versatile
SELF_IMPROVING_MODEL=

# Self-Healing
SELF_HEALING_ENABLED=false
SELF_HEALING_MAX_LOOPS=3
SELF_HEALING_AUTO_APPLY=true
SELF_HEALING_AUTO_INSTALL=true
SELF_HEALING_AUTO_ROLLBACK=true
SELF_HEALING_TEST_COMMANDS=npm run build,npm test,npm run test
SELF_HEALING_TIMEOUT_MS=120000
SELF_HEALING_MAX_DIFF_CHARS=20000
SELF_HEALING_MODEL=
SELF_HEALING_WORKDIR=.
SELF_HEALING_RUNS_DIR=./workspace/self-healing/runs
SELF_HEALING_REDACT_SECRETS=true

# Self-Upgrade
SELF_UPGRADE_ENABLED=false
SELF_UPGRADE_MAX_LOOPS=3
SELF_UPGRADE_AUTO_APPLY=true
SELF_UPGRADE_AUTO_INSTALL=true
SELF_UPGRADE_AUTO_ROLLBACK=true
SELF_UPGRADE_AUTO_REGISTER=true
SELF_UPGRADE_MODEL=
SELF_UPGRADE_ALLOWED_TARGETS=repo

# Autonomous restart after self-upgrade/self-healing
# In Docker Compose, use restart: unless-stopped so the container starts again
# after Native OpenClaw exits with AUTONOMOUS_RESTART_EXIT_CODE.
SELF_UPGRADE_AUTO_RESTART=true
SELF_HEALING_AUTO_RESTART=false
AUTONOMOUS_RESTART_MODE=exit
AUTONOMOUS_RESTART_EXIT_CODE=42
AUTONOMOUS_RESTART_DELAY_MS=1500
AUTONOMOUS_RESTART_MANUAL_ENABLED=false

# Restart notifications
RESTART_NOTIFICATION_ENABLED=true
RESTART_NOTIFY_TELEGRAM=true
RESTART_NOTIFY_EMAIL=true
RESTART_NOTIFICATION_TIMEOUT_MS=10000
RESTART_NOTIFICATION_INCLUDE_CHANGED_FILES=true
RESTART_NOTIFICATION_INCLUDE_RESTART_HINT=true

# Telegram restart notification
RESTART_TELEGRAM_CHAT_ID=
RESTART_TELEGRAM_USE_DEFAULT_CHAT=true

# Email restart notification
RESTART_EMAIL_RECIPIENT=
RESTART_EMAIL_USE_BREVO_DEFAULTS=true
RESTART_NOTIFY_AFTER_START=true

# Shared autonomous coding
AUTONOMOUS_CODING_TEMPERATURE=0.1
AUTONOMOUS_QA_TEMPERATURE=0.1

# OpenCode external coding agent
OPENCODE_AGENT_ENABLED=false
SELF_HEALING_RUNTIME=false
OPENCODE_AGENT_COMMAND=opencode
OPENCODE_AGENT_DIRECT_MODE=true
OPENCODE_AGENT_INJECT_SAFETY_PREAMBLE=false
# Optional. Leave empty to auto-detect the project root.
# In Docker this usually resolves to /app.
# Set manually only if auto-detection picks the wrong folder.
OPENCODE_AGENT_CWD=
OPENCODE_AGENT_TIMEOUT_MS=900000
OPENCODE_AGENT_IDLE_TIMEOUT_MS=0
OPENCODE_AGENT_KILL_GRACE_MS=10000
OPENCODE_AGENT_KILL_TREE=true
OPENCODE_AGENT_MAX_OUTPUT_CHARS=30000
OPENCODE_AGENT_REQUIRE_CONFIRMATION=false
OPENCODE_AGENT_USE_FOR_SELF_HEALING=false
OPENCODE_AGENT_USE_FOR_SELF_UPGRADE=false

# OpenCode CLI template
# OpenCode 1.15.x uses positional message arguments:
#   opencode run "hello"
#
# For full automation in isolated/dev environments:
OPENCODE_AGENT_ARGS_TEMPLATE=run --pure --dangerously-skip-permissions "{{task}}"

# Optional safer template without permission auto-approval:
# OPENCODE_AGENT_ARGS_TEMPLATE=run "{{task}}"

#default model for OpenCode agent when not using the router
OPENCODE_DEFAULT_MODEL=opencode/deepseek-v4-flash-free
OPENCODE_DEFAULT_SMALL_MODEL=opencode/mimo-v2.5-free

# OpenCode Zen auth bootstrap
OPENCODE_ZEN_API_KEY=
OPENCODE_AUTH_BOOTSTRAP=false
OPENCODE_AUTH_PROVIDER=opencode
OPENCODE_AUTH_FILE=
OPENCODE_AUTH_OVERWRITE=false
OPENCODE_DOCTOR_SMOKE_TEST=false

# OpenCode auto-install
OPENCODE_AUTO_INSTALL=false
OPENCODE_INSTALL_STRATEGY=npm-global
OPENCODE_INSTALL_COMMAND=
OPENCODE_INSTALL_TIMEOUT_MS=300000
OPENCODE_INSTALL_REQUIRE_APPROVAL=true
OPENCODE_INSTALL_RETRY_AFTER_INSTALL=true
OPENCODE_INSTALL_LOG_OUTPUT=true
OPENCODE_INSTALL_USE_SUDO=false

# ── Tools ─────────────────────────────────────────────────────────────────────
TOOLS_DIR=./tools

# Optional: NewsAPI key for real-time headlines (https://newsapi.org — free tier)
NEWS_API_KEY=

# Optional: Base URL for internal API tool
INTERNAL_API_BASE_URL=http://localhost:3000

# ── SambaNova ──────────────────────────────────────────────────────────────────
SAMBANOVA_API_KEY=
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1
SAMBANOVA_DEFAULT_MODEL=DeepSeek-V3.1

# ── Router ────────────────────────────────────────────────────────────────────
ROUTER_ENABLED=true          # Enable multi-provider router with auto-fallback
AUTO_FALLBACK=true           # Auto-switch to next provider on failure
AUTO_SWITCH=true             # Allow proactive provider switching

# ── Agent Capabilities ────────────────────────────────────────────────────────
REASONING_ENABLED=true       # Enable reasoning-first step before tool calls
SEMANTIC_MEMORY=true         # Enable semantic context compression

# ── Browsing (Tavily → Firecrawl fallback) ────────────────────────────────────
TAVILY_API_KEY=               # Primary browsing provider (https://tavily.com)
FIRECRAWL_API_KEY=            # Fallback browsing provider (https://firecrawl.dev)
BROWSING_TIMEOUT_MS=15000     # Request timeout in ms
BROWSING_MAX_RESULTS=5        # Max results per search

# ── System Execute ────────────────────────────────────────────────────────────
SYSTEM_EXECUTE_ENABLED=true   # Enable local shell command execution
SYSTEM_EXECUTE_POLICY=risk-based
SYSTEM_EXECUTE_ALLOW_ARBITRARY=true
SYSTEM_EXECUTE_REQUIRE_APPROVAL_FOR_DANGEROUS=true
SYSTEM_EXECUTE_WARNING_AUTO_EXECUTE=true
SYSTEM_EXECUTE_TIMEOUT=30000  # Command timeout in ms
SYSTEM_EXECUTE_MAX_OUTPUT_CHARS=20000
SYSTEM_EXECUTE_DEFAULT_CWD=workspace # workspace | project | current
SYSTEM_EXECUTE_APPROVAL_TTL_MS=300000
SYSTEM_EXECUTE_LOG_COMMANDS=true
SYSTEM_EXECUTE_REDACT_SECRETS=true

# ── ReAct Loop ────────────────────────────────────────────────────────────────
REACT_ENABLED=true            # Enable ReAct reasoning loop
REACT_MAX_STEPS=4             # Max reasoning steps per turn
